<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter xmlns="https://github.com/spotbugs/filter/3.0.0"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
                    https://raw.githubusercontent.com/spotbugs/spotbugs/3.1.0/spotbugs/etc/findbugsfilter.xsd">

    <!--
        EI_EXPOSE_REP / EI_EXPOSE_REP2:
          - JPA entities require mutable getters/setters for the persistence provider
            (Hibernate); defensive copies would break dirty-checking.
          - Spring components (services, controllers, filters, config) store
            constructor-injected singleton beans. These are container-managed, not
            externally-mutable state — copying them is meaningless.
        Intentional design decisions, not bugs.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Or>
            <!-- EN09.1 — WebSocket STOMP room isolation (planning poker): RoomAccessGrantService
                 and PokerChannelInterceptor store constructor-injected singleton beans
                 (StringRedisTemplate, MeterRegistry, WsSessionRegistry). -->
            <Package name="fr.pivot.agilite.poker.ws"/>
            <!-- EN09.1 — shared WebSocket connection plumbing: WsSessionTrackingHandlerDecoratorFactory
                 stores a constructor-injected singleton bean (WsSessionRegistry). -->
            <Package name="fr.pivot.agilite.ws"/>
            <!-- EN08.3 (US20.1.1/US09.1.1/US14.1.1) — auth EN08.3 pattern replicated from
                 pivot-collaboratif-core: PlatformAccessToken/PlatformUser/PlatformTenant/
                 PlatformTeam/PlatformTeamMember are read-only JPA mirrors of public.*;
                 TokenValidationService/RequestPrincipalResolver/WebMvcConfig store
                 constructor-injected singleton beans (repositories, AuthenticatedPrincipalResolver). -->
            <Package name="fr.pivot.agilite.auth"/>
            <Package name="fr.pivot.agilite.auth.entity"/>
            <Package name="fr.pivot.agilite.context"/>
            <Package name="fr.pivot.agilite.config"/>
            <Package name="fr.pivot.agilite.exception"/>
            <!-- US20.1.1 — RetroSession is a JPA entity (mutable getters/setters required by
                 Hibernate); RetroSessionService/RetroSessionController/JoinCodeGenerator store
                 constructor-injected singleton beans (repositories, TeamRepository,
                 TeamMemberRepository, JoinCodeGenerator). -->
            <Package name="fr.pivot.agilite.retro.session"/>
            <Package name="fr.pivot.agilite.retro.session.dto"/>
            <!-- US09.1.1 — Planning poker rooms: PokerRoom is a JPA entity (mutable
                 getters/setters required by Hibernate); PokerRoomService/PokerRoomController
                 store constructor-injected singleton beans (repository, Clock). RoomResponse's
                 cardValues is always PokerCardDeck.FIBONACCI_VALUES, an unmodifiable
                 List.of(...) constant, never independently mutated — SpotBugs cannot prove this
                 statically from the List<String> field type alone. -->
            <Package name="fr.pivot.agilite.poker"/>
            <Package name="fr.pivot.agilite.poker.dto"/>
            <!-- US14.1.1 — Wheel/WheelEntry are JPA entities (mutable getters/setters required
                 by Hibernate); Wheel.getEntries() deliberately returns the live, mutable
                 collection (not a defensive copy) so WheelService can clear()/re-add onto it for
                 the PUT full-replace semantics with orphanRemoval. WheelService/WheelController
                 store constructor-injected singleton beans (repositories, TeamMembershipService). -->
            <Package name="fr.pivot.agilite.wheel"/>
            <Package name="fr.pivot.agilite.wheel.dto"/>
            <!-- US14.1.1 — TeamMembershipService/TeamMembershipController store
                 constructor-injected singleton beans (repositories). -->
            <Package name="fr.pivot.agilite.team"/>
            <Package name="fr.pivot.agilite.team.dto"/>
            <!-- US20.1.2a — retro card/phase/WS-isolation business logic: services and the
                 channel interceptor store constructor-injected singleton beans (repositories,
                 SimpMessagingTemplate, StringRedisTemplate, MeterRegistry, WsSessionRegistry,
                 AuthenticatedPrincipalResolver, Clock); RetroCard is a JPA entity (mutable
                 getters/setters required by Hibernate). -->
            <Package name="fr.pivot.agilite.retro.card"/>
            <Package name="fr.pivot.agilite.retro.card.ws"/>
            <Package name="fr.pivot.agilite.retro.phase"/>
            <Package name="fr.pivot.agilite.retro.ws"/>
            <!-- US20.1.2a — CardsRevealedEvent/RevealResponse's `columns` is always defensively
                 copied into an unmodifiable map/lists by their compact canonical constructor
                 (RevealedColumns.immutableCopy) before being stored — mirrors this same filter's
                 existing RoomResponse.cardValues rationale above: SpotBugs cannot prove
                 immutability statically from the Map<String, List<...>> field type alone. -->
            <Package name="fr.pivot.agilite.retro.phase.dto"/>
        </Or>
    </Match>

</FindBugsFilter>
