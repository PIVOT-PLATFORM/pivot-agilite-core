<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter xmlns="https://github.com/spotbugs/filter/3.0.0"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
                    https://raw.githubusercontent.com/spotbugs/spotbugs/3.1.0/spotbugs/etc/findbugsfilter.xsd">

    <!--
        EI_EXPOSE_REP / EI_EXPOSE_REP2:
          - JPA entities require mutable getters/setters for the persistence provider
            (Hibernate); defensive copies would break dirty-checking.
          - Spring components (services, controllers, filters, config) store
            constructor-injected singleton beans. These are container-managed, not
            externally-mutable state — copying them is meaningless.
        Intentional design decisions, not bugs.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Or>
            <!-- EN09.1 — WebSocket STOMP room isolation (planning poker): RoomAccessGrantService
                 and PokerChannelInterceptor store constructor-injected singleton beans
                 (StringRedisTemplate, MeterRegistry, WsSessionRegistry). -->
            <Package name="fr.pivot.agilite.poker.ws"/>
            <!-- EN09.1 — shared WebSocket connection plumbing: WsSessionTrackingHandlerDecoratorFactory
                 stores a constructor-injected singleton bean (WsSessionRegistry). -->
            <Package name="fr.pivot.agilite.ws"/>
        </Or>
    </Match>

</FindBugsFilter>
